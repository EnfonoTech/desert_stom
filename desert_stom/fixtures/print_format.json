  "html": "\n<style>\n\t.print-format { font-family: 'Segoe UI', Arial, sans-serif; color: #333; max-width: 800px; margin: 0 auto; }\n\t.mc-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #D4A84B; padding-bottom: 10px; margin-bottom: 15px; }\n\t.mc-title { font-size: 20px; font-weight: 700; color: #1a1a2e; }\n\t.mc-subtitle { font-size: 12px; color: #666; margin-top: 4px; }\n\t.mc-badge-urgent { background: #C0392B; color: white; padding: 4px 14px; border-radius: 4px; font-size: 12px; font-weight: 600; }\n\t.mc-badge-normal { background: #95a5a6; color: white; padding: 4px 14px; border-radius: 4px; font-size: 12px; }\n\t.mc-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 15px; }\n\t.mc-info-row { display: flex; gap: 8px; font-size: 12px; }\n\t.mc-info-label { color: #888; min-width: 90px; }\n\t.mc-info-value { font-weight: 600; color: #1a1a2e; }\n\t.mc-section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; color: #D4A84B; border-bottom: 1px solid #eee; padding-bottom: 4px; margin: 15px 0 10px; letter-spacing: 0.05em; }\n\t.mc-item-title { font-size: 14px; font-weight: 700; color: #2563EB; background: #EFF6FF; padding: 6px 12px; border-radius: 4px; margin: 12px 0 8px; border-left: 3px solid #2563EB; }\n\t.mc-meas-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border: 1px solid #ddd; border-radius: 6px; overflow: hidden; margin-bottom: 10px; }\n\t.mc-meas-cell { padding: 8px 12px; border-right: 1px solid #eee; border-bottom: 1px solid #eee; }\n\t.mc-meas-cell:nth-child(3n) { border-right: none; }\n\t.mc-meas-label { font-size: 9px; text-transform: uppercase; color: #888; letter-spacing: 0.08em; }\n\t.mc-meas-value { font-size: 16px; font-weight: 600; font-family: 'Courier New', monospace; color: #1a1a2e; }\n\t.mc-meas-unit { font-size: 9px; color: #aaa; }\n\t.mc-key-cell { background: #FFF8E7; }\n\t.mc-key-cell .mc-meas-value { color: #B8892A; }\n\t.mc-options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 10px; }\n\t.mc-opt-row { font-size: 11px; display: flex; gap: 6px; }\n\t.mc-opt-label { color: #888; min-width: 100px; }\n\t.mc-opt-value { font-weight: 500; }\n\t.mc-note-box { border: 1px solid #D4A84B; border-radius: 6px; padding: 10px 14px; background: #FFFDF5; margin-top: 15px; font-size: 12px; color: #333; min-height: 40px; }\n\t.mc-signature { margin-top: 30px; display: flex; justify-content: space-between; }\n\t.mc-sig-line { border-top: 1px solid #ccc; width: 200px; padding-top: 4px; font-size: 10px; color: #888; text-align: center; }\n\t.mc-items-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; font-size: 12px; }\n\t.mc-items-table th { background: #f5f5f5; padding: 6px 8px; border: 1px solid #ddd; text-align: left; font-size: 10px; text-transform: uppercase; }\n\t.mc-items-table td { padding: 6px 8px; border: 1px solid #eee; }\n</style>\n\n<div class=\"print-format\">\n\t<div class=\"mc-header\">\n\t\t<div>\n\t\t\t<div class=\"mc-title\">Measurement Card &mdash; {{ doc.name }}</div>\n\t\t\t<div class=\"mc-subtitle\">Asafat Sahran Tailoring</div>\n\t\t</div>\n\t\t<div>\n\t\t\t{% if doc.delivery_type == \"Urgent\" %}\n\t\t\t\t<span class=\"mc-badge-urgent\">URGENT</span>\n\t\t\t{% else %}\n\t\t\t\t<span class=\"mc-badge-normal\">Normal</span>\n\t\t\t{% endif %}\n\t\t</div>\n\t</div>\n\n\t<div class=\"mc-info-grid\">\n\t\t<div class=\"mc-info-row\"><span class=\"mc-info-label\">Customer</span><span class=\"mc-info-value\">{{ doc.customer_name or \"\" }}</span></div>\n\t\t<div class=\"mc-info-row\"><span class=\"mc-info-label\">Phone</span><span class=\"mc-info-value\">{{ doc.phone_no or \"\" }}</span></div>\n\t\t<div class=\"mc-info-row\"><span class=\"mc-info-label\">Date</span><span class=\"mc-info-value\">{{ frappe.format(doc.measurement_date, {\"fieldtype\": \"Date\"}) }}</span></div>\n\t\t<div class=\"mc-info-row\"><span class=\"mc-info-label\">Promise Date</span><span class=\"mc-info-value\">{{ frappe.format(doc.promise_date, {\"fieldtype\": \"Date\"}) if doc.promise_date else \"-\" }}</span></div>\n\t\t<div class=\"mc-info-row\"><span class=\"mc-info-label\">Sales Order</span><span class=\"mc-info-value\">{{ doc.sales_order or \"-\" }}</span></div>\n\t\t<div class=\"mc-info-row\"><span class=\"mc-info-label\">Delivery Date</span><span class=\"mc-info-value\">{{ frappe.format(doc.delivery_date, {\"fieldtype\": \"Date\"}) if doc.delivery_date else \"-\" }}</span></div>\n\t\t<div class=\"mc-info-row\"><span class=\"mc-info-label\">Model / Thobe</span><span class=\"mc-info-value\">{{ doc.stitching_model or \"-\" }} / {{ doc.thobe or \"-\" }}</span></div>\n\t</div>\n\n\t{% if doc.measurement_items %}\n\t<div class=\"mc-section-title\">Items</div>\n\t<table class=\"mc-items-table\">\n\t\t<thead><tr><th>#</th><th>Item Code</th><th>Item Name</th><th>Qty</th></tr></thead>\n\t\t<tbody>\n\t\t{% for row in doc.measurement_items %}\n\t\t\t<tr><td>{{ loop.index }}</td><td>{{ row.item_code or \"\" }}</td><td>{{ row.item_name or \"\" }}</td><td>{{ row.qty or 1 }}</td></tr>\n\t\t{% endfor %}\n\t\t</tbody>\n\t</table>\n\t{% endif %}\n\n\t{%- set mdata = json.loads(doc.measurements_json or \"{}\") -%}\n\n\t{% for item_name, m in mdata.items() %}\n\n\t\t{% if mdata | length > 1 %}\n\t\t<div class=\"mc-item-title\">{{ item_name }} ({{ loop.index }} of {{ mdata | length }})</div>\n\t\t{% endif %}\n\n\t\t<div class=\"mc-section-title\">Body Measurements{% if mdata | length <= 1 %} &mdash; {{ item_name }}{% endif %}</div>\n\t\t<div class=\"mc-meas-grid\">\n\t\t\t<div class=\"mc-meas-cell mc-key-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Length</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"length\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Shoulder</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"shoulder\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell mc-key-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Sleeve Length</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"sleeve_length\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Loose 1</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"loose_1\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Loose 2</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"loose_2\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Bottom</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"bottom\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Bottom Size</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"bottom_size\", \"\") or \"-\" }}</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Sleeve Loose</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"sleeve_loose\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t\t<div class=\"mc-meas-cell\">\n\t\t\t\t<div class=\"mc-meas-label\">Shoulder Alt</div>\n\t\t\t\t<div class=\"mc-meas-value\">{{ m.get(\"shoulder_alt\", \"\") or \"-\" }}</div>\n\t\t\t\t<div class=\"mc-meas-unit\">cm</div>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<div class=\"mc-section-title\">Garment Options</div>\n\t\t<div class=\"mc-options-grid\">\n\t\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Collar Style</span><span class=\"mc-opt-value\">{{ m.get(\"collar_style\", \"\") or \"-\" }}</span></div>\n\t\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Collar Type</span><span class=\"mc-opt-value\">{{ m.get(\"collar_type\", \"\") or \"-\" }}</span></div>\n\t\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Neck Style</span><span class=\"mc-opt-value\">{{ m.get(\"neck_style\", \"\") or \"-\" }}</span></div>\n\t\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Neck Type</span><span class=\"mc-opt-value\">{{ m.get(\"neck_type\", \"\") or \"-\" }}</span></div>\n\t\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Hip</span><span class=\"mc-opt-value\">{{ m.get(\"hip\", \"\") or \"-\" }}</span></div>\n\t\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Hip Type</span><span class=\"mc-opt-value\">{{ m.get(\"hip_type\", \"\") or \"-\" }}</span></div>\n\t\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\"><strong>Special Button</strong></span><span class=\"mc-opt-value\"><strong>{{ m.get(\"special_button\", \"\") or \"-\" }}</strong></span></div>\n\t\t</div>\n\t{% endfor %}\n\n\t{% if not mdata %}\n\t<div class=\"mc-section-title\">Body Measurements</div>\n\t<div class=\"mc-meas-grid\">\n\t\t<div class=\"mc-meas-cell mc-key-cell\"><div class=\"mc-meas-label\">Length</div><div class=\"mc-meas-value\">{{ doc.length or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell\"><div class=\"mc-meas-label\">Shoulder</div><div class=\"mc-meas-value\">{{ doc.shoulder or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell mc-key-cell\"><div class=\"mc-meas-label\">Sleeve Length</div><div class=\"mc-meas-value\">{{ doc.sleeve_length or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell\"><div class=\"mc-meas-label\">Loose 1</div><div class=\"mc-meas-value\">{{ doc.loose_1 or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell\"><div class=\"mc-meas-label\">Loose 2</div><div class=\"mc-meas-value\">{{ doc.loose_2 or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell\"><div class=\"mc-meas-label\">Bottom</div><div class=\"mc-meas-value\">{{ doc.bottom or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell\"><div class=\"mc-meas-label\">Sleeve Loose</div><div class=\"mc-meas-value\">{{ doc.sleeve_loose or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell\"><div class=\"mc-meas-label\">Shoulder Alt</div><div class=\"mc-meas-value\">{{ doc.shoulder_alt or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t\t<div class=\"mc-meas-cell\"><div class=\"mc-meas-label\">Sleeve Alt</div><div class=\"mc-meas-value\">{{ doc.sleeve_alt or \"-\" }}</div><div class=\"mc-meas-unit\">cm</div></div>\n\t</div>\n\n\t<div class=\"mc-section-title\">Garment Options</div>\n\t<div class=\"mc-options-grid\">\n\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Collar Style</span><span class=\"mc-opt-value\">{{ doc.collar_style or \"-\" }}</span></div>\n\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Collar Type</span><span class=\"mc-opt-value\">{{ doc.collar_type or \"-\" }}</span></div>\n\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Neck Style</span><span class=\"mc-opt-value\">{{ doc.neck_style or \"-\" }}</span></div>\n\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Neck Type</span><span class=\"mc-opt-value\">{{ doc.neck_type or \"-\" }}</span></div>\n\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Hip</span><span class=\"mc-opt-value\">{{ doc.hip or \"-\" }}</span></div>\n\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\">Hip Type</span><span class=\"mc-opt-value\">{{ doc.hip_type or \"-\" }}</span></div>\n\t\t<div class=\"mc-opt-row\"><span class=\"mc-opt-label\"><strong>Special Button</strong></span><span class=\"mc-opt-value\"><strong>{{ doc.special_button or \"-\" }}</strong></span></div>\n\t</div>\n\t{% endif %}\n\n\t{% if doc.description_note %}\n\t<div class=\"mc-section-title\">Notes</div>\n\t<div class=\"mc-note-box\">{{ doc.description_note }}</div>\n\t{% endif %}\n\n\t<div class=\"mc-signature\">\n\t\t<div class=\"mc-sig-line\">Stitcher Signature</div>\n\t\t<div class=\"mc-sig-line\">Date</div>\n\t</div>\n</div>\n",
